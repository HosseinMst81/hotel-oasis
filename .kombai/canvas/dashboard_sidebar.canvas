    "block_a3af976a8d3c": {
      "type": "block",
      "label": "Earthy Minimalist Sidebar",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 380,
        "y": 0,
        "w": 280,
        "h": 0
      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Cinzel:wght@400;700&family=Playfair+Display:wght@400;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  body {\n    margin: 0;\n    padding: 0;\n    font-family: 'Poppins', sans-serif;\n    color: var(--color-brand-foreground, #182b2b);\n    background-color: var(--color-brand-background, #fcfbf8);\n  }\n\n  .sidebar-container {\n    height: 100vh;\n    width: 280px;\n    display: flex;\n    flex-direction: column;\n    padding: var(--space-8, 3.2rem) var(--space-6, 2.4rem);\n    border-right: 3px solid var(--color-border-base, rgba(43, 66, 51, 0.15));\n    position: relative;\n    box-sizing: border-box;\n  }\n\n  /* Inner delicate border */\n  .sidebar-container::after {\n    content: '';\n    position: absolute;\n    top: 0;\n    right: 0;\n    bottom: 0;\n    width: 1px;\n    background-color: var(--color-brand-secondary, #e0ca9b);\n  }\n\n  .nav-section-title {\n    font-family: 'Cinzel', serif;\n    font-size: 1rem;\n    letter-spacing: 0.15em;\n    color: var(--color-brand-muted, #99a59d);\n    text-transform: uppercase;\n    margin-bottom: var(--space-4, 1.6rem);\n    margin-top: var(--space-8, 3.2rem);\n  }\n\n  .nav-item {\n    display: flex;\n    align-items: center;\n    gap: var(--space-3, 1.2rem);\n    padding: var(--space-2, 0.8rem) 0;\n    color: var(--color-text-primary, #182b2b);\n    text-decoration: none;\n    font-weight: 400;\n    position: relative;\n    transition: font-weight 0.2s ease;\n  }\n\n  .nav-item i {\n    font-size: 1.8rem;\n    color: var(--color-brand-accent, #3a2512);\n  }\n\n  .nav-item.active {\n    font-weight: 700;\n  }\n\n  .active-dot {\n    width: 4px;\n    height: 4px;\n    background-color: var(--color-brand-accent, #3a2512);\n    border-radius: 50%;\n    position: absolute;\n    left: -12px;\n    opacity: 0;\n  }\n\n  .nav-item.active .active-dot {\n    opacity: 1;\n  }\n\n  .underline-hover {\n    position: absolute;\n    bottom: 2px;\n    left: 30px; /* offset for icon */\n    height: 1px;\n    background-color: var(--color-brand-secondary, #e0ca9b);\n    width: 0;\n  }\n\n  .profile-section {\n    margin-top: auto;\n    padding-top: var(--space-6, 2.4rem);\n    border-top: 1px solid var(--color-border-base, rgba(43, 66, 51, 0.15));\n  }\n\n  .user-card {\n    display: flex;\n    align-items: center;\n    gap: var(--space-3, 1.2rem);\n    margin-bottom: var(--space-4, 1.6rem);\n  }\n\n  .avatar-container {\n    position: relative;\n    width: 40px;\n    height: 40px;\n  }\n\n  .avatar {\n    width: 100%;\n    height: 100%;\n    border-radius: var(--radius-sm, 0.4rem);\n    object-fit: cover;\n  }\n\n  .status-dot {\n    position: absolute;\n    bottom: -2px;\n    right: -2px;\n    width: 10px;\n    height: 10px;\n    background-color: var(--color-brand-success, #a6c48a);\n    border: 2px solid var(--color-brand-background, #fcfbf8);\n    border-radius: 50%;\n  }\n\n  .btn-icon-sm {\n    width: 32px;\n    height: 32px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    border-radius: var(--radius-sm, 0.4rem);\n    border: 1px solid var(--color-border-base, rgba(43, 66, 51, 0.15));\n    color: var(--color-brand-foreground, #182b2b);\n    transition: all 0.2s ease;\n  }\n\n  .btn-icon-sm:hover {\n    background-color: var(--color-bg-brand-subtle, rgba(43, 66, 51, 0.08));\n    border-color: var(--color-brand-secondary, #e0ca9b);\n  }\n\n  .logo-container {\n    display: flex;\n    align-items: center;\n    gap: var(--space-3, 1.2rem);\n  }\n\n  .logo-badge {\n    width: 48px;\n    height: 48px;\n    background-color: var(--color-brand-background, #fcfbf8);\n    border: 1px solid var(--color-brand-accent, #3a2512);\n    border-radius: 50%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n</style>\n\n<div class=\"sidebar-container\" data-kid=\"1\">\n  \n  <div class=\"logo-container\" data-kid=\"2\">\n    <div class=\"logo-badge\" data-kid=\"3\">\n      <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/pine-tree.svg\" alt=\"Logo\" class=\"w-8 h-8 opacity-90\" style=\"filter: sepia(1) saturate(5) hue-rotate(-20deg) brightness(0.4);\" data-kid=\"4\">\n    </div>\n    <div class=\"flex flex-col\" data-kid=\"5\">\n      <span class=\"font-['Cinzel'] text-xl font-bold leading-none text-[var(--color-brand-accent)]\" data-kid=\"6\">HOTEL</span>\n      <span class=\"font-['Cinzel'] text-xl font-bold leading-none tracking-widest text-[var(--color-brand-accent)]\" data-kid=\"7\">OASIS</span>\n    </div>\n  </div>\n\n  \n  <nav class=\"flex-grow\" data-kid=\"8\">\n    <div class=\"nav-section-title\" data-kid=\"9\">Menu</div>\n    <div class=\"flex flex-col gap-2\" data-kid=\"10\">\n      <a href=\"#\" class=\"nav-item active\" data-kid=\"11\">\n        <span class=\"active-dot\" data-kid=\"12\"></span>\n        <i class=\"ti ti-layout\" data-kid=\"13\"></i>\n        <span data-kid=\"14\">Dashboard</span>\n        <div class=\"underline-hover\" data-kid=\"15\"></div>\n      </a>\n      <a href=\"#\" class=\"nav-item\" data-kid=\"16\">\n        <span class=\"active-dot\" data-kid=\"17\"></span>\n        <i class=\"ti ti-bookmark\" data-kid=\"18\"></i>\n        <span data-kid=\"19\">Bookings</span>\n        <div class=\"underline-hover\" data-kid=\"20\"></div>\n      </a>\n      <a href=\"#\" class=\"nav-item\" data-kid=\"21\">\n        <span class=\"active-dot\" data-kid=\"22\"></span>\n        <i class=\"ti ti-map-pin\" data-kid=\"23\"></i>\n        <span data-kid=\"24\">Cabins</span>\n        <div class=\"underline-hover\" data-kid=\"25\"></div>\n      </a>\n      <a href=\"#\" class=\"nav-item\" data-kid=\"26\">\n        <span class=\"active-dot\" data-kid=\"27\"></span>\n        <i class=\"ti ti-users\" data-kid=\"28\"></i>\n        <span data-kid=\"29\">Users</span>\n        <div class=\"underline-hover\" data-kid=\"30\"></div>\n      </a>\n    </div>\n\n    <div class=\"nav-section-title\" data-kid=\"31\">Preferences</div>\n    <div class=\"flex flex-col gap-2\" data-kid=\"32\">\n      <a href=\"#\" class=\"nav-item\" data-kid=\"33\">\n        <span class=\"active-dot\" data-kid=\"34\"></span>\n        <i class=\"ti ti-settings\" data-kid=\"35\"></i>\n        <span data-kid=\"36\">Settings</span>\n        <div class=\"underline-hover\" data-kid=\"37\"></div>\n      </a>\n    </div>\n  </nav>\n\n  \n  <div class=\"profile-section\" data-kid=\"38\">\n    <div class=\"user-card\" data-kid=\"39\">\n      <div class=\"avatar-container\" data-kid=\"40\">\n        <img src=\"https://i.pravatar.cc/100?u=hotel-manager\" alt=\"User\" class=\"avatar\" decoding=\"async\" loading=\"lazy\" data-kid=\"41\">\n        <span class=\"status-dot\" data-kid=\"42\"></span>\n      </div>\n      <div class=\"flex flex-col\" data-kid=\"43\">\n        <span class=\"text-sm font-semibold\" data-kid=\"44\">Jonas Schmedt</span>\n        <span class=\"text-xs text-[var(--color-brand-muted)]\" data-kid=\"45\">Administrator</span>\n      </div>\n    </div>\n    \n    <div class=\"flex gap-3\" data-kid=\"46\">\n      <button class=\"btn-icon-sm\" title=\"Settings\" data-kid=\"47\">\n        <i class=\"ti ti-settings-2 text-lg\" data-kid=\"48\"></i>\n      </button>\n      <button class=\"btn-icon-sm\" title=\"Logout\" data-kid=\"49\">\n        <i class=\"ti ti-logout text-lg\" data-kid=\"50\"></i>\n      </button>\n    </div>\n  </div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"51\"></script>\n<script data-kid=\"52\">\n  document.addEventListener('DOMContentLoaded', () => {\n    const navItems = document.querySelectorAll('.nav-item');\n    \n    navItems.forEach(item => {\n      const underline = item.querySelector('.underline-hover');\n      const text = item.querySelector('span:not(.active-dot)');\n      \n      item.addEventListener('mouseenter', () => {\n        gsap.to(underline, {\n          width: text.offsetWidth,\n          duration: 0.4,\n          ease: 'power2.out'\n        });\n      });\n      \n      item.addEventListener('mouseleave', () => {\n        gsap.to(underline, {\n          width: 0,\n          duration: 0.3,\n          ease: 'power2.in'\n        });\n      });\n    });\n  });\n</script>",
