    "block_ad93335f19ca": {
      "type": "block",
      "label": "Floating Oasis Sidebar",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 760,
        "y": 0,
        "w": 280,
        "h": 0
      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Cinzel:wght@400;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --color-brand-primary: oklch(0.38 0.06 150);\n    --color-brand-secondary: oklch(0.85 0.08 85);\n    --color-brand-background: oklch(0.98 0.01 85);\n    --color-brand-foreground: oklch(0.18 0.02 150);\n    --color-brand-light: oklch(0.99 0.005 85);\n    --color-brand-muted: oklch(0.62 0.02 150);\n    --color-bg-brand-subtle: color-mix(in oklch, var(--color-brand-primary) 8%, transparent);\n    --radius-xl: 2rem;\n    --shadow-lg: 0 10px 15px -3px rgb(43 66 51 / 0.1), 0 4px 6px -4px rgb(43 66 51 / 0.1);\n    --font-primary: 'Cinzel', serif;\n    --font-secondary: 'Poppins', sans-serif;\n    --gradient-bg-brand: linear-gradient(135deg, var(--color-brand-primary), oklch(0.25 0.05 60));\n  }\n\n  body {\n    margin: 0;\n    padding: 1rem;\n    background-color: oklch(0.94 0.01 150); /* Subtle light gray-green backdrop for the floating effect */\n    min-height: 100vh;\n    font-family: var(--font-secondary);\n  }\n\n  .sidebar-pill {\n    transition: background-color 0.3s ease, color 0.3s ease;\n  }\n\n  .avatar-ring {\n    padding: 2px;\n    background: var(--gradient-bg-brand);\n  }\n</style>\n\n<div class=\"flex flex-col h-[calc(100vh-2rem)] w-[248px] bg-[var(--color-brand-background)] rounded-(--radius-xl) shadow-(--shadow-lg) border border-[var(--color-brand-primary)]/5 overflow-hidden\" data-kid=\"1\">\n  \n  \n  <div class=\"px-6 pt-8 pb-4\" data-kid=\"2\">\n    <div class=\"flex items-center gap-3\" data-kid=\"3\">\n       <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/monstera-leaf.svg\" class=\"w-8 h-8 opacity-90\" style=\"filter: invert(24%) sepia(21%) saturate(545%) hue-rotate(95deg) brightness(92%) contrast(88%);\" alt=\"Leaf Logo\" decoding=\"async\" loading=\"lazy\" data-kid=\"4\">\n      <h1 class=\"text-[var(--color-brand-primary)] font-(--font-primary) text-xl font-bold tracking-[0.15em] m-0\" data-kid=\"5\">\n        OASIS\n      </h1>\n    </div>\n    <div class=\"w-8 h-[2px] bg-[var(--color-brand-secondary)] mt-3\" data-kid=\"6\"></div>\n  </div>\n\n  \n  <nav class=\"flex-1 px-4 mt-6 space-y-2\" data-kid=\"7\">\n    \n    <a href=\"#\" class=\"sidebar-pill group flex items-center gap-3 px-5 py-3 rounded-full bg-[var(--color-brand-primary)] text-[var(--color-brand-light)] no-underline\" data-kid=\"8\">\n      <i class=\"ti ti-grid text-lg\" data-kid=\"9\"></i>\n      <span class=\"text-sm font-medium\" data-kid=\"10\">Dashboard</span>\n    </a>\n\n    \n    <a href=\"#\" class=\"sidebar-pill group flex items-center gap-3 px-5 py-3 rounded-full text-[var(--color-brand-foreground)] hover:bg-[var(--color-bg-brand-subtle)] no-underline\" data-kid=\"11\">\n      <i class=\"ti ti-calendar-week text-lg text-[var(--color-brand-muted)] group-hover:text-[var(--color-brand-primary)]\" data-kid=\"12\"></i>\n      <span class=\"text-sm font-medium\" data-kid=\"13\">Bookings</span>\n    </a>\n\n    <a href=\"#\" class=\"sidebar-pill group flex items-center gap-3 px-5 py-3 rounded-full text-[var(--color-brand-foreground)] hover:bg-[var(--color-bg-brand-subtle)] no-underline\" data-kid=\"14\">\n      <i class=\"ti ti-tent text-lg text-[var(--color-brand-muted)] group-hover:text-[var(--color-brand-primary)]\" data-kid=\"15\"></i>\n      <span class=\"text-sm font-medium\" data-kid=\"16\">Cabins</span>\n    </a>\n\n    <a href=\"#\" class=\"sidebar-pill group flex items-center gap-3 px-5 py-3 rounded-full text-[var(--color-brand-foreground)] hover:bg-[var(--color-bg-brand-subtle)] no-underline\" data-kid=\"17\">\n      <i class=\"ti ti-user-circle text-lg text-[var(--color-brand-muted)] group-hover:text-[var(--color-brand-primary)]\" data-kid=\"18\"></i>\n      <span class=\"text-sm font-medium\" data-kid=\"19\">Users</span>\n    </a>\n\n    <a href=\"#\" class=\"sidebar-pill group flex items-center gap-3 px-5 py-3 rounded-full text-[var(--color-brand-foreground)] hover:bg-[var(--color-bg-brand-subtle)] no-underline\" data-kid=\"20\">\n      <i class=\"ti ti-sliders text-lg text-[var(--color-brand-muted)] group-hover:text-[var(--color-brand-primary)]\" data-kid=\"21\"></i>\n      <span class=\"text-sm font-medium\" data-kid=\"22\">Settings</span>\n    </a>\n  </nav>\n\n  \n  <div class=\"px-4 pb-8 space-y-4\" data-kid=\"23\">\n    \n    <div class=\"flex items-center gap-3 p-3 rounded-2xl bg-[var(--color-brand-primary)]/5 border border-[var(--color-brand-primary)]/10\" data-kid=\"24\">\n      <div class=\"avatar-ring rounded-full shrink-0\" data-kid=\"25\">\n        <img src=\"https://i.pravatar.cc/80?u=jonas\" class=\"w-10 h-10 rounded-full border-2 border-[var(--color-brand-background)]\" alt=\"User Avatar\" decoding=\"async\" loading=\"lazy\" data-kid=\"26\">\n      </div>\n      <div class=\"flex flex-col overflow-hidden\" data-kid=\"27\">\n        <span class=\"text-sm font-semibold text-[var(--color-brand-foreground)] truncate\" data-kid=\"28\">Jonas Schmedtmann</span>\n        <span class=\"text-xs text-[var(--color-brand-muted)]\" data-kid=\"29\">Administrator</span>\n      </div>\n    </div>\n\n    \n    <button class=\"sidebar-pill w-full flex items-center justify-center gap-2 px-5 py-3 rounded-full border border-[var(--color-brand-primary)]/10 text-[var(--color-brand-foreground)] hover:text-red-600 hover:bg-red-50 hover:border-red-100 transition-colors\" data-kid=\"30\">\n      <i class=\"ti ti-door-open text-lg\" data-kid=\"31\"></i>\n      <span class=\"text-sm font-medium\" data-kid=\"32\">Logout</span>\n    </button>\n  </div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"33\"></script>\n<script data-kid=\"34\">\n  document.addEventListener('DOMContentLoaded', () => {\n    const pills = document.querySelectorAll('.sidebar-pill');\n    \n    pills.forEach(pill => {\n      pill.addEventListener('mouseenter', () => {\n        gsap.to(pill, {\n          scale: 1.02,\n          duration: 0.3,\n          ease: \"power2.out\"\n        });\n      });\n      \n      pill.addEventListener('mouseleave', () => {\n        gsap.to(pill, {\n          scale: 1,\n          duration: 0.3,\n          ease: \"power2.inOut\"\n        });\n      });\n    });\n\n    // Subtle entrance animation\n    gsap.from('.sidebar-pill', {\n      x: -20,\n      opacity: 0,\n      stagger: 0.05,\n      duration: 0.8,\n      ease: \"power3.out\",\n      delay: 0.2\n    });\n  });\n</script>",
