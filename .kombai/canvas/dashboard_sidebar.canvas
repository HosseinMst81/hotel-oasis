    "block_564d56b8ccf2": {
      "type": "block",
      "label": "Grand Entrance Sidebar",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 0,
        "y": 0,
        "w": 280,
        "h": 0
      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Poppins:wght@300;400;500;600&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    /* Design System Tokens (Mapping from src/design/GlobalStyles.ts) */\n    --color-brand-primary: oklch(0.38 0.06 150);\n    --color-brand-secondary: oklch(0.85 0.08 85);\n    --color-brand-background: oklch(0.98 0.01 85);\n    --color-brand-dark: oklch(0.12 0.02 150);\n    --color-brand-muted: oklch(0.62 0.02 150);\n    \n    --font-primary: 'Cinzel', serif;\n    --font-secondary: 'Poppins', sans-serif;\n    \n    --space-1: 0.4rem;\n    --space-2: 0.8rem;\n    --space-3: 1.2rem;\n    --space-4: 1.6rem;\n    --space-8: 3.2rem;\n    \n    --radius-md: 0.8rem;\n    --radius-full: 9999px;\n\n    /* Interactive mix simulation for static view */\n    --color-primary-focus: color-mix(in oklch, var(--color-brand-primary), white 12%);\n  }\n\n  body {\n    margin: 0;\n    padding: 0;\n    background-color: var(--color-brand-background);\n  }\n\n  .sidebar {\n    width: 280px;\n    height: 100vh;\n    background-color: var(--color-brand-primary);\n    color: var(--color-brand-background);\n    display: flex;\n    flex-direction: column;\n    padding: var(--space-8) 0;\n    font-family: var(--font-secondary);\n    box-shadow: 4px 0 24px rgba(0, 0, 0, 0.15);\n    position: relative;\n    border-right: 1px solid var(--color-brand-dark);\n  }\n\n  .logo-area {\n    padding: 0 var(--space-6);\n    margin-bottom: var(--space-10);\n    text-align: center;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: var(--space-2);\n  }\n\n  .logo-crest {\n    width: 48px;\n    height: 48px;\n    filter: brightness(0) saturate(100%) invert(88%) sepia(18%) saturate(735%) hue-rotate(352deg) brightness(95%) contrast(87%); /* Mapping to --color-brand-secondary Gold */\n    margin-bottom: var(--space-2);\n  }\n\n  .logo-text {\n    font-family: var(--font-primary);\n    font-size: 2.2rem;\n    font-weight: 700;\n    letter-spacing: 0.05em;\n    color: var(--color-brand-secondary);\n    text-transform: uppercase;\n    margin: 0;\n  }\n\n  .nav-list {\n    flex: 1;\n    display: flex;\n    flex-direction: column;\n    gap: var(--space-1);\n    padding: 0 var(--space-3);\n  }\n\n  .nav-item {\n    display: flex;\n    align-items: center;\n    gap: var(--space-4);\n    padding: var(--space-3) var(--space-4);\n    border-radius: var(--radius-md);\n    text-decoration: none;\n    color: rgba(255, 255, 255, 0.6);\n    font-weight: 500;\n    font-size: 1.5rem;\n    transition: all 0.3s ease;\n    cursor: pointer;\n  }\n\n  .nav-item i {\n    font-size: 2rem;\n    color: rgba(255, 255, 255, 0.5);\n    transition: color 0.3s ease;\n  }\n\n  .nav-item:hover {\n    color: var(--color-brand-background);\n    background-color: rgba(255, 255, 255, 0.05);\n  }\n\n  .nav-item.active {\n    background-color: var(--color-primary-focus);\n    color: var(--color-brand-secondary);\n    position: relative;\n  }\n\n  .nav-item.active i {\n    color: var(--color-brand-secondary);\n  }\n\n  .nav-item.active::before {\n    content: '';\n    position: absolute;\n    left: 0;\n    top: 20%;\n    height: 60%;\n    width: 4px;\n    background-color: var(--color-brand-secondary);\n    border-radius: 0 4px 4px 0;\n  }\n\n  .user-block {\n    margin-top: auto;\n    padding: var(--space-6) var(--space-4);\n    border-top: 1px solid rgba(255, 255, 255, 0.1);\n    display: flex;\n    align-items: center;\n    gap: var(--space-3);\n  }\n\n  .avatar-container {\n    width: 44px;\n    height: 44px;\n    border-radius: var(--radius-full);\n    border: 2px solid var(--color-brand-secondary);\n    padding: 2px;\n  }\n\n  .avatar {\n    width: 100%;\n    height: 100%;\n    border-radius: var(--radius-full);\n    object-fit: cover;\n  }\n\n  .user-info {\n    flex: 1;\n    overflow: hidden;\n  }\n\n  .user-name {\n    font-size: 1.4rem;\n    font-weight: 600;\n    color: var(--color-brand-background);\n    display: block;\n    white-space: nowrap;\n    overflow: hidden;\n    text-overflow: ellipsis;\n  }\n\n  .user-role {\n    font-size: 1.1rem;\n    color: rgba(255, 255, 255, 0.5);\n    display: block;\n  }\n\n  .logout-btn {\n    color: rgba(255, 255, 255, 0.4);\n    font-size: 1.8rem;\n    padding: var(--space-2);\n    border-radius: var(--radius-md);\n    transition: all 0.2s ease;\n  }\n\n  .logout-btn:hover {\n    background-color: rgba(239, 68, 68, 0.1);\n    color: #ef4444;\n  }\n</style>\n\n<aside class=\"sidebar\" data-kid=\"1\">\n  <div class=\"logo-area\" data-kid=\"2\">\n    <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/monstera-leaf.svg\" alt=\"Hotel Oasis Crest\" class=\"logo-crest\" data-kid=\"3\">\n    <h1 class=\"logo-text\" data-kid=\"4\">Hotel Oasis</h1>\n  </div>\n\n  <nav class=\"nav-list\" data-kid=\"5\">\n    <a class=\"nav-item active\" data-kid=\"6\">\n      <i class=\"ti ti-layout-dashboard\" data-kid=\"7\"></i>\n      <span data-kid=\"8\">Dashboard</span>\n    </a>\n    <a class=\"nav-item\" data-kid=\"9\">\n      <i class=\"ti ti-calendar-check\" data-kid=\"10\"></i>\n      <span data-kid=\"11\">Bookings</span>\n    </a>\n    <a class=\"nav-item\" data-kid=\"12\">\n      <i class=\"ti ti-home\" data-kid=\"13\"></i>\n      <span data-kid=\"14\">Cabins</span>\n    </a>\n    <a class=\"nav-item\" data-kid=\"15\">\n      <i class=\"ti ti-users\" data-kid=\"16\"></i>\n      <span data-kid=\"17\">Users</span>\n    </a>\n    <a class=\"nav-item\" data-kid=\"18\">\n      <i class=\"ti ti-settings\" data-kid=\"19\"></i>\n      <span data-kid=\"20\">Settings</span>\n    </a>\n  </nav>\n\n  <div class=\"user-block\" data-kid=\"21\">\n    <div class=\"avatar-container\" data-kid=\"22\">\n      <img src=\"https://i.pravatar.cc/100?u=jonas\" alt=\"User Avatar\" class=\"avatar\" data-kid=\"23\">\n    </div>\n    <div class=\"user-info\" data-kid=\"24\">\n      <span class=\"user-name\" data-kid=\"25\">Jonas Schmedtmann</span>\n      <span class=\"user-role\" data-kid=\"26\">Administrator</span>\n    </div>\n    <button class=\"logout-btn\" title=\"Logout\" data-kid=\"27\">\n      <i class=\"ti ti-logout\" data-kid=\"28\"></i>\n    </button>\n  </div>\n</aside>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"29\"></script>\n<script data-kid=\"30\">\n  // Subtle horizontal shift on hover for nav items\n  const navItems = document.querySelectorAll('.nav-item');\n  \n  navItems.forEach(item => {\n    item.addEventListener('mouseenter', () => {\n      if (!item.classList.contains('active')) {\n        gsap.to(item, {\n          x: 6,\n          duration: 0.3,\n          ease: 'power2.out'\n        });\n      }\n    });\n    \n    item.addEventListener('mouseleave', () => {\n      gsap.to(item, {\n        x: 0,\n        duration: 0.3,\n        ease: 'power2.out'\n      });\n    });\n  });\n</script>",
