      "html": "<div class=\"min-h-screen bg-(--k-color-bg-page) p-10 font-(--k-font-family-body)\" data-kid=\"0\">\n  \n  <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"1\">\n  <style data-kid=\"2\">\n    @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Cinzel:wght@400;700&display=swap');\n  </style>\n\n  <div class=\"relative mx-auto max-w-6xl\" data-kid=\"3\">\n    \n    \n    <div class=\"mb-6 flex items-center justify-between gap-4 rounded-(--k-radius-md) bg-(--k-color-accent) px-6 py-4 text-white shadow-(--k-shadow-lg) transition-all\" data-kid=\"4\">\n      <div class=\"flex items-center gap-4\" data-kid=\"5\">\n        <div class=\"flex h-8 w-8 items-center justify-center rounded-full bg-white/20 text-sm font-bold\" data-kid=\"6\">3</div>\n        <div data-kid=\"7\">\n          <h4 class=\"m-0 text-sm font-bold uppercase tracking-wider text-white\" data-kid=\"8\">Cabins Selected</h4>\n          <p class=\"m-0 text-xs text-white/70\" data-kid=\"9\">Perform actions on all selected items</p>\n        </div>\n      </div>\n      <div class=\"flex gap-3\" data-kid=\"10\">\n        <button class=\"flex items-center gap-2 rounded-(--k-radius-sm) bg-white/10 px-4 py-2 text-xs font-bold transition-colors hover:bg-white/20\" data-kid=\"11\">\n          <i class=\"ti ti-edit\" data-kid=\"12\"></i> BULK EDIT\n        </button>\n        <button class=\"flex items-center gap-2 rounded-(--k-radius-sm) bg-red-500/20 px-4 py-2 text-xs font-bold text-red-100 transition-colors hover:bg-red-500/30\" data-kid=\"13\">\n          <i class=\"ti ti-trash\" data-kid=\"14\"></i> DELETE PERMANENTLY\n        </button>\n        <div class=\"h-8 w-px bg-white/20\" data-kid=\"15\"></div>\n        <button class=\"text-xs font-bold text-white/60 hover:text-white\" data-kid=\"16\">DESELECT ALL</button>\n      </div>\n    </div>\n\n    \n    <div class=\"mb-8 flex items-center justify-between gap-6\" data-kid=\"17\">\n      <div class=\"relative flex-1 max-w-md group\" data-kid=\"18\">\n        <i class=\"ti ti-search absolute left-4 top-1/2 -translate-y-1/2 text-(--k-color-text-muted) transition-colors group-focus-within:text-(--k-color-primary)\" data-kid=\"19\"></i>\n        <input type=\"text\" placeholder=\"Search cabins by name, type or location...\" class=\"w-full rounded-(--k-radius-sm) border border-(--k-color-border) bg-white py-3 pl-12 pr-4 text-sm shadow-(--k-shadow-sm) transition-all focus:border-(--k-color-primary) focus:ring-4 focus:ring-(--k-color-primary)/10 focus:outline-hidden\" data-kid=\"20\">\n      </div>\n      <div class=\"flex items-center gap-3\" data-kid=\"21\">\n        <button class=\"group flex items-center gap-2 rounded-(--k-radius-sm) border border-(--k-color-border) bg-white px-5 py-3 text-sm font-bold text-(--k-color-text-primary) shadow-(--k-shadow-sm) transition-all hover:bg-(--k-color-bg-surface-hover) hover:border-(--k-color-primary)\" data-kid=\"22\">\n          <i class=\"ti ti-adjustments-horizontal text-(--k-color-text-muted) group-hover:text-(--k-color-primary)\" data-kid=\"23\"></i> \n          <span data-kid=\"24\">FILTERS</span>\n        </button>\n        <button class=\"group flex items-center gap-2 rounded-(--k-radius-sm) border border-(--k-color-border) bg-white px-5 py-3 text-sm font-bold text-(--k-color-text-primary) shadow-(--k-shadow-sm) transition-all hover:bg-(--k-color-bg-surface-hover) hover:border-(--k-color-primary)\" data-kid=\"25\">\n          <i class=\"ti ti-columns text-(--k-color-text-muted) group-hover:text-(--k-color-primary)\" data-kid=\"26\"></i>\n          <span data-kid=\"27\">COLUMNS</span>\n        </button>\n      </div>\n    </div>\n\n    \n    <div class=\"grid grid-cols-[60px_2fr_1fr_1fr_1fr_120px] items-center px-6 py-4 border-b-(--k-border-width-thick) border-(--k-color-border) bg-transparent\" data-kid=\"28\">\n      <div class=\"flex justify-center\" data-kid=\"29\">\n        <input type=\"checkbox\" class=\"h-5 w-5 rounded border-(--k-color-border) text-(--k-color-primary) focus:ring-(--k-color-primary)\" data-kid=\"30\">\n      </div>\n      <div class=\"text-xs font-bold uppercase tracking-widest text-(--k-color-text-muted)\" data-kid=\"31\">Cabin Detail</div>\n      <div class=\"text-xs font-bold uppercase tracking-widest text-(--k-color-text-muted)\" data-kid=\"32\">Type</div>\n      <div class=\"text-xs font-bold uppercase tracking-widest text-(--k-color-text-muted)\" data-kid=\"33\">Capacity</div>\n      <div class=\"text-xs font-bold uppercase tracking-widest text-(--k-color-text-muted)\" data-kid=\"34\">Price / Night</div>\n      <div class=\"text-xs font-bold uppercase tracking-widest text-(--k-color-text-muted) text-right\" data-kid=\"35\">Row Actions</div>\n    </div>\n\n    \n    <div class=\"mt-6 space-y-4\" data-kid=\"36\">\n      \n      \n      <div class=\"group relative grid grid-cols-[60px_2fr_1fr_1fr_1fr_120px] items-center rounded-(--k-radius-md) border-2 border-(--k-color-secondary) bg-(--k-color-secondary)/5 px-6 py-5 shadow-(--k-shadow-sm) transition-all hover:shadow-(--k-shadow-md)\" data-kid=\"37\">\n        <div class=\"flex justify-center\" data-kid=\"38\">\n          <input type=\"checkbox\" checked class=\"h-5 w-5 rounded border-(--k-color-border) text-(--k-color-primary)\" data-kid=\"39\">\n        </div>\n        <div class=\"flex items-center gap-4\" data-kid=\"40\">\n          <div class=\"h-12 w-12 rounded-(--k-radius-sm) bg-(--k-color-primary)/10 flex items-center justify-center\" data-kid=\"41\">\n            <i class=\"ti ti-home text-(--k-color-primary) text-xl\" data-kid=\"42\"></i>\n          </div>\n          <div data-kid=\"43\">\n            <div class=\"font-bold text-(--k-color-text-primary)\" data-kid=\"44\">Cabin 001</div>\n            <div class=\"text-xs text-(--k-color-text-secondary)\" data-kid=\"45\">Luxury Retreat • High Ridge</div>\n          </div>\n        </div>\n   