vertical text-xl\" data-kid=\"73\"></i>\n                </button>\n              </td>\n            </tr>\n\n            \n            <tr class=\"opacity-40 border-l-4 border-transparent\" data-kid=\"74\">\n              <td class=\"p-5 text-center\" data-kid=\"75\"><div class=\"w-4 h-4 skeleton mx-auto rounded\" data-kid=\"76\"></div></td>\n              <td class=\"p-5\" data-kid=\"77\"><div class=\"flex items-center gap-4\" data-kid=\"78\"><div class=\"w-16 h-10 skeleton rounded\" data-kid=\"79\"></div><div class=\"w-32 h-4 skeleton rounded\" data-kid=\"80\"></div></div></td>\n              <td class=\"p-5\" data-kid=\"81\"><div class=\"w-24 h-4 skeleton rounded\" data-kid=\"82\"></div></td>\n              <td class=\"p-5\" data-kid=\"83\"><div class=\"w-16 h-4 skeleton rounded\" data-kid=\"84\"></div></td>\n              <td class=\"p-5\" data-kid=\"85\"><div class=\"w-16 h-4 skeleton rounded\" data-kid=\"86\"></div></td>\n              <td class=\"p-5\" data-kid=\"87\"><div class=\"w-20 h-6 skeleton rounded-full\" data-kid=\"88\"></div></td>\n              <td class=\"p-5 text-center\" data-kid=\"89\"><div class=\"w-8 h-8 skeleton mx-auto rounded-full\" data-kid=\"90\"></div></td>\n            </tr>\n          </tbody>\n        </table>\n      </div>\n\n      \n      <div class=\"px-6 py-4 border-t border-[var(--k-color-border)] bg-gray-50 flex items-center justify-between\" data-kid=\"91\">\n        <p class=\"text-[var(--k-font-size-xs)] text-[var(--k-color-text-muted)] font-medium\" data-kid=\"92\">\n          Showing <span class=\"text-[var(--k-color-text-primary)] font-bold\" data-kid=\"93\">1</span> to <span class=\"text-[var(--k-color-text-primary)] font-bold\" data-kid=\"94\">10</span> of <span class=\"text-[var(--k-color-text-primary)] font-bold\" data-kid=\"95\">48</span> results\n        </p>\n        <div class=\"flex items-center gap-2\" data-kid=\"96\">\n          <button disabled class=\"px-4 py-2 border border-[var(--k-color-border)] rounded-[var(--k-radius-md)] text-[var(--k-font-size-xs)] font-bold opacity-50 cursor-not-allowed\" data-kid=\"97\">Previous</button>\n          <div class=\"flex items-center px-2\" data-kid=\"98\">\n            <button class=\"w-8 h-8 rounded-full bg-[var(--k-color-primary)] text-white text-[var(--k-font-size-xs)] font-bold\" data-kid=\"99\">1</button>\n            <button class=\"w-8 h-8 rounded-full hover:bg-gray-200 text-[var(--k-font-size-xs)] font-bold\" data-kid=\"100\">2</button>\n            <button class=\"w-8 h-8 rounded-full hover:bg-gray-200 text-[var(--k-font-size-xs)] font-bold\" data-kid=\"101\">3</button>\n            <span class=\"px-2 text-[var(--k-color-text-muted)]\" data-kid=\"102\">...</span>\n            <button class=\"w-8 h-8 rounded-full hover:bg-gray-200 text-[var(--k-font-size-xs)] font-bold\" data-kid=\"103\">5</button>\n          </div>\n          <button class=\"px-4 py-2 border border-[var(--k-color-border)] rounded-[var(--k-radius-md)] text-[var(--k-font-size-xs)] font-bold hover:bg-white transition-all\" data-kid=\"104\">Next</button>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"py-12 flex flex-col items-center justify-center bg-[var(--k-color-bg-surface)] rounded-[var(--k-radius-lg)] border border-dashed border-[var(--k-color-border)] opacity-60\" data-kid=\"105\">\n      <i class=\"ti ti-leaf text-5xl text-[var(--k-color-text-muted)] mb-4\" data-kid=\"106\"></i>\n      <h3 class=\"font-cinzel text-[var(--k-font-size-lg)] font-bold mb-1\" data-kid=\"107\">No cabins found</h3>\n      <p class=\"text-[var(--k-font-size-sm)] text-[var(--k-color-text-muted)]\" data-kid=\"108\">Try adjusting your filters or search terms.</p>\n    </div>\n\n    \n    <div id=\"bulk-bar\" class=\"fixed bottom-10 left-1/2 -translate-x-1/2 z-50\" data-kid=\"109\">\n      <div class=\"bg-[var(--k-color-brand-dark, #121212)] text-white px-8 py-4 rounded-[var(--k-radius-full)] shadow-[var(--k-shadow-lg)] flex items-center gap-8 min-w-[400px]\" data-kid=\"110\">\n        <div class=\"flex items-center gap-3\" data-kid=\"111\">\n          <span class=\"w-7 h-7 bg-[var(--k-color-secondary)] text-[var(--k-color-primary)] rounded-full flex items-center justify-center font-bold text-xs\" data-kid=\"112\">3</span>\n          <span class=\"text-sm font-bold uppercase tracking-wider\" data-kid=\"113\">Cabins Selected</span>\n        </div>\n        <div class=\"h-6 w-px bg-white/20\" data-kid=\"114\"></div>\n        <div class=\"flex items-center gap-4\" data-kid=\"115\">\n          <button class=\"flex items-center gap-2 text-xs font-bold hover:text-[var(--k-color-secondary)] transition-colors\" data-kid=\"116\">\n            <i class=\"ti ti-edit-2\" data-kid=\"117\"></i> Edit Bulk\n          </button>\n          <button class=\"flex items-center gap-2 text-xs font-bold hover:text-red-400 transition-colors\" data-kid=\"118\">\n            <i class=\"ti ti-trash-2\" data-kid=\"119\"></i> Delete All\n          </button>\n          <button class=\"ml-4 text-xs font-medium text-white/50 hover:text-white transition-colors underline underline-offset-4\" data-kid=\"120\">\n            Clear\n          </button>\n        </div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"121\"></script>\n<script data-kid=\"122\">\n  // Initial animation for the bulk actions bar\n  gsap.from(\"#bulk-bar\", {\n    y: 100,\n    opacity: 0,\n    duration: 0.8,\n    ease: \"back.out(1.7)\",\n    delay: 0.5\n  });\n</script>",
