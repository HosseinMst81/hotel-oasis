      "html": "<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"0\">\n<style data-kid=\"1\">\n  @import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Poppins:wght@400;500;600;700&display=swap');\n\n  .font-heading { font-family: var(--k-font-family-heading); }\n  .font-body { font-family: var(--k-font-family-body); }\n\n  /* Custom Scrollbar for the table */\n  .table-scroll::-webkit-scrollbar {\n    width: 6px;\n    height: 6px;\n  }\n  .table-scroll::-webkit-scrollbar-track {\n    background: transparent;\n  }\n  .table-scroll::-webkit-scrollbar-thumb {\n    background: var(--k-color-border);\n    border-radius: 10px;\n  }\n  .table-scroll::-webkit-scrollbar-thumb:hover {\n    background: var(--k-color-text-secondary);\n  }\n\n  /* Sticky Action Drawer */\n  .action-drawer {\n    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n    transform: translateX(100%);\n  }\n  tr:hover .action-drawer {\n    transform: translateX(0);\n  }\n\n  /* Skeleton Animation */\n  @keyframes shimmer {\n    0% { background-position: -200% 0; }\n    100% { background-position: 200% 0; }\n  }\n  .skeleton {\n    background: linear-gradient(90deg, var(--k-color-bg-surface-hover) 25%, var(--k-color-border) 50%, var(--k-color-bg-surface-hover) 75%);\n    background-size: 200% 100%;\n    animation: shimmer 1.5s infinite linear;\n  }\n</style>\n\n<div class=\"min-h-screen bg-[var(--k-color-bg-page)] p-8 font-body text-[var(--k-color-text-primary)]\" data-kid=\"2\">\n  \n  <div class=\"mx-auto max-w-6xl overflow-hidden rounded-[var(--k-radius-lg)] bg-[var(--k-color-bg-surface)] shadow-[var(--k-shadow-md)]\" data-kid=\"3\">\n    \n    \n    <div class=\"flex items-center justify-between border-b border-[var(--k-color-border)] px-6 py-5\" data-kid=\"4\">\n      <h2 class=\"font-heading text-xl font-bold tracking-tight text-[var(--k-color-primary)]\" data-kid=\"5\">Luxurious Cabins</h2>\n      \n      <div class=\"flex items-center gap-4\" data-kid=\"6\">\n        \n        <div class=\"relative\" data-kid=\"7\">\n          <i class=\"ti ti-search absolute top-1/2 left-3 -translate-y-1/2 text-[var(--k-color-text-secondary)]\" data-kid=\"8\"></i>\n          <input type=\"text\" placeholder=\"Search cabins...\" class=\"h-10 w-64 rounded-[var(--k-radius-md)] border border-[var(--k-color-border)] bg-[var(--k-color-bg-page)] pl-10 pr-4 text-sm outline-hidden transition-all focus:border-[var(--k-color-primary)] focus:ring-2 focus:ring-[var(--k-color-primary)]/20\" data-kid=\"9\">\n        </div>\n        \n        \n        <button class=\"flex h-10 items-center gap-2 rounded-[var(--k-radius-md)] border border-[var(--k-color-border)] bg-white px-3 text-sm font-medium transition-colors hover:bg-[var(--k-color-bg-surface-hover)]\" data-kid=\"10\">\n          <i class=\"ti ti-layout-grid text-lg\" data-kid=\"11\"></i>\n          <span data-kid=\"12\">Columns</span>\n        </button>\n      </div>\n    </div>\n\n    \n    \n    <div class=\"relative z-20\" data-kid=\"13\">\n      <div class=\"absolute inset-x-0 top-0 flex items-center justify-between border-b border-[var(--k-color-secondary)]/30 bg-[var(--k-color-primary)] px-6 py-3 text-[var(--k-color-secondary)]\" data-kid=\"14\">\n        <div class=\"flex items-center gap-3\" data-kid=\"15\">\n          <span class=\"flex h-6 w-6 items-center justify-center rounded-full bg-[var(--k-color-secondary)] text-[var(--k-color-primary)] text-xs font-bold\" data-kid=\"16\">3</span>\n          <span class=\"text-sm font-semibold tracking-wide\" data-kid=\"17\">CABINS SELECTED</span>\n        </div>\n        <div class=\"flex items-center gap-4\" data-kid=\"18\">\n          <button class=\"flex items-center gap-2 text-sm font-bold uppercase tracking-widest transition-opacity hover:opacity-80\" data-kid=\"19\">\n            <i class=\"ti ti-trash\" data-kid=\"20\"></i>\n            Delete\n          </button>\n          <div class=\"h-4 w-px bg-[var(--k-color-secondary)]/20\" data-kid=\"21\"></div>\n          <button class=\"text-sm font-bold uppercase tracking-widest transition-opacity hover:opacity-80\" data-kid=\"22\">Clear Selection</button>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"table-scroll relative overflow-auto pt-[48px]\" data-kid=\"23\"> \n      <table class=\"w-full border-collapse text-left text-sm\" role=\"grid\" data-kid=\"24\">\n        <thead class=\"sticky top-0 z-10 bg-[var(--k-color-bg-surface-hover)] font-heading text-xs uppercase tracking-wider text-[var(--k-color-text-secondary)]\" data-kid=\"25\">\n          <tr data-kid=\"26\">\n            <th class=\"w-12 px-6 py-4\" data-kid=\"27\">\n              <input type=\"checkbox\" checked class=\"h-4 w-4 rounded border-[var(--k-color-border)] accent-[var(--k-color-primary)]\" data-kid=\"28\">\n            </th>\n            <th class=\"border-r border-[var(--k-color-border)]/30 px-6 py-4\" data-kid=\"29\">\n              <div class=\"flex items-center gap-2\" data-kid=\"30\">\n                <span data-kid=\"31\">Cabin</span>\n                <i class=\"ti ti-chevron-up text-[var(--k-color-primary)]\" data-kid=\"32\"></i>\n              </div>\n            </th>\n            <th class=\"border-r border-[var(--k-color-border)]/30 px-6 py-4\" data-kid=\"33\">Capacity</th>\n            <th class=\"bg-[var(--k-color-primary)]/5 border-r border-[var(--k-color-border)]/30 px-6 py-4\" data-kid=\"34\">\n              <div class=\"flex items-center gap-2\" data-kid=\"35\">\n                <span class=\"text-[var(--k-color-primary)]\" data-kid=\"36\">Price</span>\n                <i class=\"ti ti-chevron-down text-[var(--k-color-primary)]\" data-kid=\"37\"></i>\n              </div>\n            </th>\n            <th class=\"border-r border-[var(--k-color-border)]/30 px-6 py-4\" data-kid=\"38\">Discount</th>\n            <th class=\"border-r border-[var(--k-color-border)]/30 px-6 py-4\" data-kid=\"39\">Status</th>\n            <th class=\"sticky right-0 bg-[var(--k-color-bg-surface-hover)] px-6 py-4 text-center\" data-kid=\"40\">Actions</th>\n          </tr>\n        </thead>\n        <tbody class=\"divide-y divide-[var(--k-color-border)]\" data-kid=\"41\">\n          \n          <tr class=\"bg-[var(--k-color-success)]/5 group transition-colors hover:bg-[var(--k-color-bg-surface-hover)]\" aria-selected=\"true\" data-kid=\"42\">\n            <td class=\"px-6 py-4\" data-kid=\"43\">\n              <input type=\"checkbox\" checked class=\"h-4 w-4 rounded border-[var(--k-color-border)] accent-[var(--k-color-primary)]\" data-kid=\"44\">\n            </td>\n            <td class=\"px-6 py-4 font-semibold text-[var(--k-color-text-primary)]\" data-kid=\"45\">001 · Royal Suite</td>\n            <td class=\"px-6 py-4\" data-kid=\"46\">Up to 8 guests</td>\n            <td class=\"bg-[var(--k-color-primary)]/5 px-6 py-4 font-bold text-[var(--k-color-primary)]\" data-kid=\"47\">$550.00</td>\n            <td class=\"px-6 py-4 text-[var(--k-color-success)]\" data-kid=\"48\">-$50.00</td>\n            <td class=\"px-6 py-4\" data-kid=\"49\">\n              <span class=\"inline-flex rounded-full bg-[var(--k-color-success)]/10 px-2.5 py-0.5 text-xs font-bold text-[var(--k-color-success)]\" data-kid=\"50\">AVAILABLE</span>\n            </td>\n            \n            <td class=\"sticky right-0 bg-white group-hover:bg-[var(--k-color-bg-surface-hover)] px-6 py-4\" data-kid=\"51\">\n              <div class=\"flex items-center justify-center gap-3\" data-kid=\"52\">\n                <button class=\"text-[var(--k-color-text-secondary)] transition-colors hover:text-[var(--k-color-primary)]\" data-kid=\"53\"><i class=\"ti ti-edit text-lg\" data-kid=\"54\"></i></button>\n                <button class=\"text-[var(--k-color-text-secondary)] transition-colors hover:text-[var(--k-color-error)]\" data-kid=\"55\"><i class=\"ti ti-trash text-lg\" data-kid=\"56\"></i></button>\n              </div>\n            </td>\n          </tr>\n\n          \n          <tr class=\"group transition-colors hover:bg-[var(--k-color-bg-surface-hover)]\" data-kid=\"57\">\n            <td class=\"px-6 py-4\" data-kid=\"58\">\n              <input type=\"checkbox\" class=\"h-4 w-4 rounded border-[var(--k-color-border)] accent-[var(--k-color-primary)]\" data-kid=\"59\">\n            </td>\n            <td class=\"px-6 py-4 font-semibold\" data-kid=\"60\">002 · Pine Retreat</td>\n            <td class=\"px-6 py-4\" data-kid=\"61\">Up to 4 guests</td>\n            <td class=\"bg-[var(--k-color-primary)]/5 px-6 py-4 font-bold\" data-kid=\"62\">$350.00</td>\n            <td class=\"px-6 py-4 text-[var(--k-color-text-muted)]\" data-kid=\"63\">—</td>\n            <td class=\"px-6 py-4\" data-kid=\"64\">\n              <span class=\"inline-flex rounded-full bg-[var(--k-color-warning)]/10 px-2.5 py-0.5 text-xs font-bold text-[var(--k-color-warning)]\" data-kid=\"65\">BOOKED</span>\n            </td>\n            <td class=\"sticky right-0 bg-white group-hover:bg-[var(--k-color-bg-surface-hover)] px-6 py-4\" data-kid=\"66\">\n              <div class=\"flex items-center justify-center gap-3\" data-kid=\"67\">\n                <button class=\"text-[var(--k-color-text-secondary)] hover:text-[var(--k-color-primary)]\" data-kid=\"68\"><i class=\"ti ti-edit text-lg\" data-kid=\"69\"></i></button>\n                <button class=\"text-[var(--k-color-text-secondary)] hover:text-[var(--k-color-error)]\" data-kid=\"70\"><i class=\"ti ti-trash text-lg\" data-kid=\"71\"></i></button>\n              </div>\n            </td>\n          </tr>\n\n          \n          <tr class=\"bg-[var(--k-color-success)]/5 group transition-colors hover:bg-[var(--k-color-bg-surface-hover)]\" data-kid=\"72\">\n            <td class=\"px-6 py-4\" data-kid=\"73\">\n              <input type=\"checkbox\" checked class=\"h-4 w-4 rounded border-[var(--k-color-border)] accent-[var(--k-color-primary)]\" data-kid=\"74\">\n            </td>\n            <td class=\"px-6 py-4 font-semibold\" data-kid=\"75\">003 · Mountain Den</td>\n            <td class=\"px-6 py-4\" data-kid=\"76\">Up to 2 guests</td>\n            <td class=\"bg-[var(--k-color-primary)]/5 px-6 py-4 font-bold\" data-kid=\"77\">$250.00</td>\n            <td class=\"px-6 py-4 text-[var(--k-color-success)]\" data-kid=\"78\">-$20.00</td>\n            <td class=\"px-6 py-4\" data-kid=\"79\">\n              <span class=\"inline-flex rounded-full bg-[var(--k-color-success)]/10 px-2.5 py-0.5 text-xs font-bold text-[var(--k-color-success)]\" data-kid=\"80\">AVAILABLE</span>\n            </td>\n            <td class=\"sticky right-0 bg-white group-hover:bg-[var(--k-color-bg-surface-hover)] px-6 py-4\" data-kid=\"81\">\n              <div class=\"flex items-center justify-center gap-3\" data-kid=\"82\">\n                <button class=\"text-[var(--k-color-text-secondary)] hover:text-[var(--k-color-primary)]\" data-kid=\"83\"><i class=\"ti ti-edit text-lg\" data-kid=\"84\"></i></button>\n                <button class=\"text-[var(--k-color-text-secondary)] hover:text-[var(--k-color-error)]\" data-kid=\"85\"><i class=\"ti ti-trash text-lg\" data-kid=\"86\"></i></button>\n              </div>\n            </td>\n          </tr>\n\n          \n          <tr class=\"aria-hidden\" data-kid=\"87\">\n            <td class=\"px-6 py-4\" data-kid=\"88\"><div class=\"skeleton h-4 w-4 rounded\" data-kid=\"89\"></div></td>\n            <td class=\"px-6 py-4\" data-kid=\"90\"><div class=\"skeleton h-4 w-48 rounded\" data-kid=\"91\"></div></td>\n            <td class=\"px-6 py-4\" data-kid=\"92\"><div class=\"skeleton h-4 w-24 rounded\" data-kid=\"93\"></div></td>\n            <td class=\"px-6 py-4 bg-[var(--k-color-primary)]/5\" data-kid=\"94\"><div class=\"skeleton h-4 w-16 rounded\" data-kid=\"95\"></div></td>\n            <td class=\"px-6 py-4\" data-kid=\"96\"><div class=\"skeleton h-4 w-16 rounded\" data-kid=\"97\"></div></td>\n            <td class=\"px-6 py-4\" data-kid=\"98\"><div class=\"skeleton h-6 w-20 rounded-full\" data-kid=\"99\"></div></td>\n            <td class=\"sticky right-0 bg-white px-6 py-4\" data-kid=\"100\"><div class=\"skeleton mx-auto h-4 w-12 rounded\" data-kid=\"101\"></div></td>\n          </tr>\n        </tbody>\n      </table>\n    </div>\n\n    \n    <div class=\"flex items-center justify-between border-t border-[var(--k-color-border)] px-6 py-4\" data-kid=\"102\">\n      <p class=\"text-sm text-[var(--k-color-text-secondary)]\" data-kid=\"103\">\n        Showing <span class=\"font-bold text-[var(--k-color-text-primary)]\" data-kid=\"104\">1</span> to <span class=\"font-bold text-[var(--k-color-text-primary)]\" data-kid=\"105\">10</span> of <span class=\"font-bold text-[var(--k-color-text-primary)]\" data-kid=\"106\">50</span> cabins\n      </p>\n      \n      <div class=\"flex items-center gap-2\" data-kid=\"107\">\n        <button class=\"flex h-9 w-9 items-center justify-center rounded-[var(--k-radius-md)] border border-[var(--k-color-border)] transition-colors hover:bg-[var(--k-color-bg-surface-hover)] disabled:opacity-30\" disabled data-kid=\"108\">\n          <i class=\"ti ti-arrow-left\" data-kid=\"109\"></i>\n        </button>\n        <div class=\"flex gap-1\" data-kid=\"110\">\n          <button class=\"h-9 w-9 rounded-[var(--k-radius-md)] bg-[var(--k-color-primary)] font-bold text-white\" data-kid=\"111\">1</button>\n          <button class=\"h-9 w-9 rounded-[var(--k-radius-md)] transition-colors hover:bg-[var(--k-color-bg-surface-hover)]\" data-kid=\"112\">2</button>\n          <button class=\"h-9 w-9 rounded-[var(--k-radius-md)] transition-colors hover:bg-[var(--k-color-bg-surface-hover)]\" data-kid=\"113\">3</button>\n        </div>\n        <button class=\"flex h-9 w-9 items-center justify-center rounded-[var(--k-radius-md)] border border-[var(--k-color-border)] transition-colors hover:bg-[var(--k-color-bg-surface-hover)]\" data-kid=\"114\">\n          <i class=\"ti ti-arrow-right\" data-kid=\"115\"></i>\n        </button>\n      </div>\n    </div>\n  </div>\n</div>",
